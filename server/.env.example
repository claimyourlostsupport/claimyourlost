PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/claimyourlost
JWT_SECRET=change-this-to-a-long-random-string-in-production
CLIENT_URL=http://localhost:5173
# Public share link domain (e.g. https://claimyourlost.com). Sets og:url / canonical; Cloudflare proxies /share/social/* here.
# SHARE_PUBLIC_ORIGIN=https://claimyourlost.com
# Absolute API origin for /uploads in og:image when SHARE_PUBLIC_ORIGIN is the Pages domain (Render URL).
# API_PUBLIC_ORIGIN=https://claimyourlost-2.onrender.com

# Uploaded images: max edge in px (default 120; max 2000), JPEG quality 60–95
# IMAGE_MAX_EDGE=120
# IMAGE_JPEG_QUALITY=80

# Optional: token for admin cleanup routes, e.g. POST /admin/clear-all-items,
# /admin/clear-item/:id, /admin/clear-social-post/:id (see server/routes/admin.js).
# CLEAR_DATA_TOKEN=change-this-to-a-long-random-secret

# Optional: permanent image storage (Cloudinary). If unset, server/uploads is used.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Optional: real SMS OTP (Twilio). If unset, any 6-digit code works (mock).
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# Optional: default country code for 10-digit local numbers (e.g. 91 for India)
# DEFAULT_COUNTRY_CODE=91
