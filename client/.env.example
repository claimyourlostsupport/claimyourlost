# Use /api proxy in dev (see vite.config.js). Production: full https API URL (required for Cloudflare _redirects share rule).
# Production build writes: /share/social/* -> {VITE_API_URL}/share/social/:splat 302
VITE_API_URL=/api

# Canonical site URL — used for Social Hub share links (/share/social/:id on your domain). Required for Facebook on custom domain.
# VITE_PUBLIC_SITE_URL=https://claimyourlost.com

# PayPal support link (PayPal.Me or any full URL). Required if default paypal.me slug does not match your account.
# VITE_PAYPAL_SUPPORT_URL=https://paypal.me/yourPayPalMeName
